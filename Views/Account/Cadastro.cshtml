@model UsuarioViewModel
@{
    ViewData["Title"] = "Cadastro";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cadastro</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background: #0f172a;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: Arial, Helvetica, sans-serif;
        }
        .cadastro-container {
            width: 100%;
            max-width: 420px;
            background: #1e293b;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0px 0px 25px rgba(0,0,0,0.5);
        }
        .cadastro-title {
            text-align: center;
            color: white;
            font-size: 32px;
            font-weight: bold;
            margin-bottom: 10px;
        }
        .cadastro-subtitle {
            text-align: center;
            color: #94a3b8;
            margin-bottom: 30px;
        }
        .form-label { color: #e2e8f0; font-weight: 500; }
        .form-control {
            background-color: #334155;
            border: none;
            color: white;
            height: 50px;
        }
        .form-control:focus {
            background-color: #334155;
            color: white;
            box-shadow: 0 0 0 0.2rem rgba(59,130,246,.25);
        }
        .form-control::placeholder { color: #94a3b8; }
        .btn-cadastro {
            width: 100%;
            height: 50px;
            background: #16a34a;
            border: none;
            border-radius: 10px;
            font-size: 18px;
            font-weight: bold;
            color: white;
            transition: 0.3s;
        }
        .btn-cadastro:hover { background: #15803d; }
        .erro {
            background: #7f1d1d;
            color: #fecaca;
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 20px;
            text-align: center;
        }
        .icon-input { position: relative; }
        .icon-input i {
            position: absolute;
            top: 16px;
            left: 15px;
            color: #94a3b8;
        }
        .icon-input input { padding-left: 45px; }
        .footer-text {
            text-align: center;
            margin-top: 20px;
            color: #94a3b8;
        }
        .footer-text a { color: #3b82f6; text-decoration: none; }
        .footer-text a:hover { text-decoration: underline; }
    </style>
</head>

<body>
    <div class="cadastro-container">

        <div class="cadastro-title">Criar Conta</div>
        <div class="cadastro-subtitle">Preencha os dados para se cadastrar</div>

        @if (ViewBag.Erro != null)
        {
            <div class="erro">@ViewBag.Erro</div>
        }

        <form method="post" asp-controller="Account" asp-action="Cadastro">

            <div class="mb-4">
                <label class="form-label">Nome completo</label>
                <div class="icon-input">
                    <i class="fa fa-id-card"></i>
                    <input asp-for="Nome" class="form-control" placeholder="Digite seu nome" />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Login</label>
                <div class="icon-input">
                    <i class="fa fa-user"></i>
                    <input asp-for="Login" class="form-control" placeholder="Escolha um login" />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Senha</label>
                <div class="icon-input">
                    <i class="fa fa-lock"></i>
                    <input asp-for="Senha" type="password" class="form-control" placeholder="Crie uma senha" />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Confirmar Senha</label>
                <div class="icon-input">
                    <i class="fa fa-lock"></i>
                    <input asp-for="ConfirmarSenha" type="password" class="form-control" placeholder="Repita a senha" />
                </div>
            </div>

            <button type="submit" class="btn btn-cadastro">
                Criar Conta
            </button>

             @if (ViewBag.Erro != null)
            {
                <div class="erro">
                    @ViewBag.Erro
                </div>
            }

        </form>

        <div class="footer-text">
            Já possui conta?
            <a asp-controller="Account" asp-action="Login">Fazer login</a>
        </div>

    </div>
</body>
</html>