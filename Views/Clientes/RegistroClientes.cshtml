@model ClientesViewModel
@{
    ViewBag.Title = "Cadastro Clientes";
}

<h2>@ViewBag.Title</h2>

<form asp-action="Salvar" method="post">
    <input type="hidden" asp-for="Id" />
    @if(Model.Id != 0)
    {
        <div class="form-group mb-3">
            <a asp-action="Exportar" asp-route-id="@Model.Id" class="btn btn-secondary">Exportar</a>
        </div>
    }
    <div class="form-group mb-3">
        <label class="form-label">CPF/CNPJ</label>
        <input class="form-control" type="text" asp-for="CPF" />
        <span asp-validation-for="CPF" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label class="form-label">Inscrição Estadual</label>
        <input class="form-control" type="text" asp-for="InscricaoEstatudal" />
        <span asp-validation-for="InscricaoEstatudal" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label class="form-label">Nome</label>
        <input class="form-control" type="text" asp-for="Nome" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label class="form-label">Nome Fantasia</label>
        <input class="form-control" type="text" asp-for="NomeFantasia" />
        <span asp-validation-for="NomeFantasia" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label class="form-label">Número Endereço</label>
        <input class="form-control" type="text" asp-for="NumeroEndereco" />
        <span asp-validation-for="NumeroEndereco" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label class="form-label">Bairro</label>
        <input class="form-control" type="text" asp-for="Bairro" />
        <span asp-validation-for="Bairro" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label class="form-label">Cidade</label>
        <select class="form-control" asp-for="Cidades" asp-items="Model.Cidades"></select>
    </div>
    <div class="form-group mb-3">
        <label class="form-label">Estado</label>
        <input class="form-control" type="text" asp-for="Estado" />
        <span asp-validation-for="Estado" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label class="form-label">Data de Nascimento / Abertura</label>
        <input class="form-control" type="date" asp-for="DataNascimento" />
        <span asp-validation-for="DataNascimento" class="text-danger"></span>
    </div>
        <div class="form-group">
            <input class="btn btn-primary" type="submit" value="Salvar" />        
        </div>
</form>
