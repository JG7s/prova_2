@model ClientesViewModel

@{
    ViewData["Title"] = "Cadastro Clientes";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Cadastro Clientes</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            padding: 30px 20px;
            min-height: 100vh;
            background: #0f172a;
            font-family: Arial, Helvetica, sans-serif;
        }

        .page-container {
            width: 100%;
            max-width: 700px;
            margin: 0 auto;
        }

        /* Header */
        .page-header {
            background: #1e293b;
            padding: 28px 35px;
            border-radius: 20px;
            box-shadow: 0px 0px 25px rgba(0,0,0,0.5);
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
        }

        .page-title {
            color: white;
            font-size: 26px;
            font-weight: bold;
            margin: 0;
        }

        .page-title i {
            color: #3b82f6;
            margin-right: 10px;
        }

        .btn-exportar {
            height: 42px;
            padding: 0 20px;
            background: #1e3a5f;
            color: #93c5fd;
            border: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: bold;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.3s;
        }

        .btn-exportar:hover {
            background: #1e40af;
            color: #bfdbfe;
        }

        /* Form card */
        .form-container {
            background: #1e293b;
            padding: 35px 40px;
            border-radius: 20px;
            box-shadow: 0px 0px 25px rgba(0,0,0,0.5);
        }

        .form-label {
            color: #e2e8f0;
            font-weight: 500;
            margin-bottom: 6px;
        }

        .form-control,
        .form-select {
            background-color: #334155;
            border: none;
            color: white;
            height: 50px;
        }

        .form-control:focus,
        .form-select:focus {
            background-color: #334155;
            color: white;
            box-shadow: 0 0 0 0.2rem rgba(59,130,246,.25);
        }

        .form-control::placeholder {
            color: #94a3b8;
        }

        .form-select option {
            background-color: #334155;
            color: white;
        }

        /* Validation */
        .text-danger {
            color: #f87171 !important;
            font-size: 13px;
            margin-top: 4px;
            display: block;
        }

        .validation-summary-errors {
            background: #7f1d1d;
            color: #fecaca;
            padding: 12px 16px;
            border-radius: 10px;
            margin-bottom: 24px;
            font-size: 14px;
        }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 18px;
        }

        /* Icon input */
        .icon-input {
            position: relative;
        }

        .icon-input i {
            position: absolute;
            top: 16px;
            left: 15px;
            color: #94a3b8;
            z-index: 1;
        }

        .icon-input .form-control,
        .icon-input .form-select {
            padding-left: 45px;
        }

        /* Divider */
        .section-label {
            color: #64748b;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 18px;
            margin-top: 8px;
        }

        .divider {
            border-top: 1px solid #334155;
            margin: 24px 0;
        }

        /* Two columns */
        .row-cols-form {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0 20px;
        }

        /* Submit */
        .btn-salvar {
            width: 100%;
            height: 50px;
            background: #2563eb;
            border: none;
            border-radius: 10px;
            font-size: 17px;
            font-weight: bold;
            color: white;
            transition: 0.3s;
            cursor: pointer;
            margin-top: 8px;
        }

        .btn-salvar:hover {
            background: #1d4ed8;
            color: white;
        }

        /* Back link */
        .footer-text {
            text-align: center;
            margin-top: 20px;
            color: #94a3b8;
        }

        .footer-text a {
            color: #3b82f6;
            text-decoration: none;
        }

        .footer-text a:hover {
            text-decoration: underline;
        }
    </style>
</head>

<body>

    <div class="page-container">

        <!-- Header -->
        <div class="page-header">
            <h1 class="page-title">
                <i class="fa fa-user-plus"></i>
                @(Model.Id != 0 ? "Editar Cliente" : "Novo Cliente")
            </h1>

            @if (Model.Id != 0)
            {
                <a asp-action="Exportar" asp-route-id="@Model.Id" class="btn-exportar">
                    <i class="fa fa-file-export"></i> Exportar
                </a>
            }
        </div>

        <!-- Form -->
        <div class="form-container">
            <form asp-action="Salvar" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />

                <div class="section-label">Dados fiscais</div>

                <div class="row-cols-form">
                    <div class="mb-4">
                        <label class="form-label">CPF / CNPJ</label>
                        <div class="icon-input">
                            <i class="fa fa-id-card"></i>
                            <input class="form-control" type="text" asp-for="CPF" placeholder="000.000.000-00" />
                        </div>
                        <span asp-validation-for="CPF" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Inscrição Estadual</label>
                        <div class="icon-input">
                            <i class="fa fa-file-alt"></i>
                            <input class="form-control" type="text" asp-for="InscricaoEstatudal" placeholder="000.000.000.000" />
                        </div>
                        <span asp-validation-for="InscricaoEstatudal" class="text-danger"></span>
                    </div>
                </div>

                <div class="divider"></div>
                <div class="section-label">Identificação</div>

                <div class="mb-4">
                    <label class="form-label">Nome</label>
                    <div class="icon-input">
                        <i class="fa fa-user"></i>
                        <input class="form-control" type="text" asp-for="Nome" placeholder="Nome completo" />
                    </div>
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Nome Fantasia</label>
                    <div class="icon-input">
                        <i class="fa fa-store"></i>
                        <input class="form-control" type="text" asp-for="NomeFantasia" placeholder="Nome fantasia" />
                    </div>
                    <span asp-validation-for="NomeFantasia" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Data de Nascimento / Abertura</label>
                    <div class="icon-input">
                        <i class="fa fa-calendar"></i>
                        <input class="form-control" type="date" asp-for="DataNascimento" />
                    </div>
                    <span asp-validation-for="DataNascimento" class="text-danger"></span>
                </div>

                <div class="divider"></div>
                <div class="section-label">Endereço</div>

                <div class="row-cols-form">
                    <div class="mb-4">
                        <label class="form-label">Bairro</label>
                        <div class="icon-input">
                            <i class="fa fa-map-marker-alt"></i>
                            <input class="form-control" type="text" asp-for="Bairro" placeholder="Bairro" />
                        </div>
                        <span asp-validation-for="Bairro" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Número</label>
                        <div class="icon-input">
                            <i class="fa fa-hashtag"></i>
                            <input class="form-control" type="text" asp-for="NumeroEndereco" placeholder="Nº" />
                        </div>
                        <span asp-validation-for="NumeroEndereco" class="text-danger"></span>
                    </div>
                </div>

                <div class="row-cols-form">
                    <div class="mb-4">
                        <label class="form-label">Cidade</label>
                        <div class="icon-input">
                            <i class="fa fa-city"></i>
                            <select class="form-control" asp-for="Cidade" asp-items="Model.Cidades">
                                <option value="">Selecione uma cidade</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Estado</label>
                        <div class="icon-input">
                            <i class="fa fa-map"></i>
                            <input class="form-control" type="text" asp-for="Estado" placeholder="UF" />
                        </div>
                        <span asp-validation-for="Estado" class="text-danger"></span>
                    </div>
                </div>

                <<div class="form-group mb-3"> 
                    <label class="form-label">Imagem</label>
                    <input asp-for="Imagem" type="file" />
                </div>
                <div class="form-group mb-3">         
                    <img src="@Model.CaminhoImagem" width="300" />
                </div>   
                <button type="submit" class="btn-salvar" value="Salvar">
                    <i class="fa fa-save me-2"></i> Salvar
                </button>

            </form>
        </div>

        <div class="footer-text">
            <a asp-action="Index">
                <i class="fa fa-arrow-left me-1"></i> Voltar para Clientes
            </a>
        </div>

    </div>

</body>
</html>
