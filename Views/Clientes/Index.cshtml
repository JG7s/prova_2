@model IEnumerable<ClientesViewModel>

@{
    ViewData["Title"] = "Clientes";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Clientes</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            padding: 30px 20px;
            min-height: 100vh;
            background: #0f172a;
            font-family: Arial, Helvetica, sans-serif;
        }
        .page-container {
            width: 100%;
            max-width: 1400px;
            margin: 0 auto;
        }
        .page-header {
            background: #1e293b;
            padding: 30px 35px;
            border-radius: 20px;
            box-shadow: 0px 0px 25px rgba(0,0,0,0.5);
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 15px;
        }
        .page-title {
            color: white;
            font-size: 28px;
            font-weight: bold;
            margin: 0;
        }
        .page-title span {
            color: #3b82f6;
        }
        .header-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .btn-novo {
            height: 42px;
            padding: 0 20px;
            background: #2563eb;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: bold;
            color: white;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.3s;
        }
        .btn-novo:hover {
            background: #1d4ed8;
            color: white;
        }
        .btn-voltar {
            height: 42px;
            padding: 0 20px;
            background: #334155;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            color: #94a3b8;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.3s;
        }
        .btn-voltar:hover {
            background: #475569;
            color: white;
        }
        .sucesso {
            background: #14532d;
            color: #bbf7d0;
            padding: 12px 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            text-align: center;
        }
        .table-container {
            background: #1e293b;
            border-radius: 20px;
            box-shadow: 0px 0px 25px rgba(0,0,0,0.5);
            overflow: hidden;
        }
        .table {
            margin: 0;
            color: #1f1f1f;
            background: #0f172a;
        }
        .table thead tr {
            background: #0f172a;
        }
        .table thead th {
            color: #353535;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            font-weight: 600;
            padding: 16px 18px;
            border: none;
            white-space: nowrap;
        }
        .table tbody tr {
            border-top: 1px solid #334155;
            transition: background 0.2s;
        }
        .table tbody tr:hover {
            background: #263348;
        }
        .table tbody td {
            padding: 14px 18px;
            border: none;
            color: #444444;
            font-size: 14px;
            white-space: nowrap;
        }
        .table tbody td:first-child {
            color: #64748b;
            font-size: 13px;
        }
        .btn-editar {
            padding: 5px 12px;
            background: #78350f;
            color: #fde68a;
            border: none;
            border-radius: 6px;
            font-size: 13px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: 0.2s;
        }
        .btn-editar:hover {
            background: #92400e;
            color: #fde68a;
        }
        .btn-excluir {
            padding: 5px 12px;
            background: #7f1d1d;
            color: #fecaca;
            border: none;
            border-radius: 6px;
            font-size: 13px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: 0.2s;
        }
        .btn-excluir:hover {
            background: #991b1b;
            color: #fecaca;
        }
        .btn-exportar {
            padding: 5px 12px;
            background: #1e3a5f;
            color: #93c5fd;
            border: none;
            border-radius: 6px;
            font-size: 13px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: 0.2s;
        }
        .btn-exportar:hover {
            background: #1e40af;
            color: #bfdbfe;
        }
        .actions-cell {
            display: flex;
            gap: 6px;
            align-items: center;
        }
        .empty-state {
            text-align: center;
            padding: 50px 20px;
            color: #64748b;
        }
        .empty-state i {
            font-size: 40px;
            margin-bottom: 12px;
            display: block;
        }
        .table-responsive {
            border-radius: 20px;
        }
    </style>
</head>

<body>
    <div class="page-container">

        @if (TempData["Mensagem"] != null)
        {
            <div class="sucesso">
                <i class="fa fa-check-circle me-2"></i>@TempData["Mensagem"]
            </div>
        }

        <div class="page-header">
            <h1 class="page-title">
                <i class="fa fa-users me-2" style="color:#3b82f6;"></i>
                Clientes
            </h1>
            <div class="header-actions">
                <a class="btn-novo" asp-action="RegistroClientes">
                    <i class="fa fa-plus"></i> Novo Cliente
                </a>
                <a class="btn-voltar" asp-controller="Home" asp-action="Index">
                    <i class="fa fa-arrow-left"></i> Voltar
                </a>
            </div>
        </div>

        <div class="table-container">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>CPF</th>
                            <th>Insc. Estadual</th>
                            <th>Nome</th>
                            <th>Nome Fantasia</th>
                            <th>Nº End.</th>
                            <th>Bairro</th>
                            <th>Cidade</th>
                            <th>Estado</th>
                            <th>Dt. Nascimento</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (ClientesViewModel Clientes in Model)
                        {
                            <tr>
                                <td>@Clientes.Id</td>
                                <td>@Clientes.CPF</td>
                                <td>@Clientes.InscricaoEstatudal</td>
                                <td>@Clientes.Nome</td>
                                <td>@Clientes.NomeFantasia</td>
                                <td>@Clientes.NumeroEndereco</td>
                                <td>@Clientes.Bairro</td>
                                <td>@Clientes.Cidade</td>
                                <td>@Clientes.Estado</td>
                                <td>@Clientes.DataNascimento.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <div class="actions-cell">
                                        <a class="btn-editar" asp-action="RegistroClientes" asp-route-id="@Clientes.Id">
                                            <i class="fa fa-pen"></i> Editar
                                        </a>
                                        <a class="btn-excluir" asp-action="Excluir" asp-route-id="@Clientes.Id">
                                            <i class="fa fa-trash"></i> Excluir
                                        </a>
                                        <a class="btn-exportar" asp-action="Exportar" asp-route-id="@Clientes.Id">
                                            <i class="fa fa-file-export"></i> Exportar
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="11">
                                    <div class="empty-state">
                                        <i class="fa fa-users-slash"></i>
                                        Nenhum cliente cadastrado.
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</body>
</html>